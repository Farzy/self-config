# {{ ansible_managed }}
[user]
    name = {{ me_name }}
    email = {{ me_email_personal }}
[color]
    pager = true
    diff = auto
    status = auto
    branch = auto
    interactive = auto
    ui = auto
[alias]
    st = status
    ci = commit
    co = checkout
    fp = format-patch
    last = log -1 HEAD
    ll = log --pretty=format:"%C(yellow)%h%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate --numstat
    ld = log --pretty=format:"%C(yellow)%h\\ %C(green)%ad%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate --date=short --graph
    ls = log --pretty=format:"%C(green)%h\\ %C(yellow)[%ad]%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate --date=relative
    lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
    oops = commit --amend -a -C HEAD
    prev = checkout HEAD^1
    next = "!sh -c 'git log --reverse --pretty=%H master | awk \"/$(git rev-parse HEAD)/{getline;print}\" | xargs git checkout'"
    b = branch -v
	r = remote -v
	t = tag -l
    unstage = reset HEAD --
	uncommit = reset --soft HEAD^
    spull = !git pull && git submodule sync --recursive && git submodule update --init --recursive
    # See https://stackoverflow.com/a/21284342/59855
    grep-all = !sh -c 'git grep "$0" "$@" "$(git for-each-ref --format=\"%(refname)\" refs/)"'
	sync-main = "!f() {\n    if [ -n \"$(git status --porcelain)\" ]; then\n        echo \"Error: You have uncommitted changes. Please commit or stash them first.\"\n        exit 1\n    fi\n    curr=$(git branch --show-current)\n    if git show-ref --verify --quiet refs/heads/main; then\n        main=\"main\"\n    else\n        main=\"master\"\n    fi\n    if [ \"$curr\" != \"$main\" ]; then\n        git checkout \"$main\"\n        case \"$curr\" in\n            feat/*|fix/*|feature/*|bugfix/*|docs/*|style/*|refactor/*|perf/*|test/*|build/*|ci/*|chore/*|revert/*)\n                echo \"Force deleting local branch: $curr\"\n                git branch -D \"$curr\"\n                ;;\n        esac\n    fi\n    echo \"Fetching and pruning remote branches...\"\n    git fetch --prune\n    echo \"Updating $main with pull --rebase...\"\n    git pull --rebase origin \"$main\"\n}; f"
[merge]
	#stat = true
[core]
    #pager = cat
    pager = less -FRX
    excludesfile = {{ me_home }}/.gitignore_global
    quotepath = false
[github]
  user = Farzy
  token = {{ passwords_github_token }}
[http]
  sslVerify = false
[gist]
  browse = no
[difftool "sourcetree"]
  cmd = opendiff \"$LOCAL\" \"$REMOTE\"
  path =
[mergetool "sourcetree"]
  cmd = /Applications/SourceTree.app/Contents/Resources/opendiff-w.sh \"$LOCAL\" \"$REMOTE\" -ancestor \"$BASE\" -merge \"$MERGED\"
  trustExitCode = true
[push]
    default = upstream
    autoSetupRemote = true
[credential]
    helper = osxkeychain
[pull]
    rebase = true
[init]
    defaultBranch = master
